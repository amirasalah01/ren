# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=rentify
DB_USER=postgres
DB_PASSWORD=postgres
# DB_HOST is overridden to "db" by docker-compose; keep "localhost" for local dev
DB_HOST=localhost
DB_PORT=5432
# Use "disable" for local Docker (no SSL on the local postgres container)
# Use "require" when connecting to a managed DB like AWS RDS
DB_SSL_MODE=disable

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ─── Media / S3 (optional) ────────────────────────────────────────────────────
# Set USE_S3=True to store uploads in S3 instead of the local filesystem
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=rentify-media-storage
AWS_S3_REGION_NAME=us-east-1

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@rentify.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
